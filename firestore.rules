
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Robust admin check: checks for existence in roles_admin OR matches the super admin email.
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email == "admin1@neu.edu.ph"
      );
    }

    function isNotBlocked(userId) {
      // Use .get() with a default value to safely handle cases where the isBlocked field might be missing.
      return get(/databases/$(database)/documents/userProfiles/$(userId)).data.get('isBlocked', false) == false;
    }

    // --- COLLECTION RULES ---

    match /roles_admin/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update: if isSignedIn() 
                             && request.auth.uid == userId 
                             && request.auth.token.email == "admin1@neu.edu.ph";
      allow delete: if false;
    }

    match /userProfiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) 
                    && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    match /userProfiles/{userId}/libraryVisits/{visitId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) 
                    && request.resource.data.userId == userId
                    && isNotBlocked(userId);
      allow update: if isOwner(userId) 
                    && request.resource.data.userId == resource.data.userId
                    && isNotBlocked(userId);
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /{path=**}/libraryVisits/{visitId} {
      allow list: if isAdmin();
    }
  }
}
