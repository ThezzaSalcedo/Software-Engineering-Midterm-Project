rules_version = '2';

/**
 * NEU Library Visitor App - Security Rules
 * 
 * CORE PHILOSOPHY:
 * This ruleset enforces a strict user-ownership model combined with Database-Based Access Control (DBAC).
 * Authorization is primarily driven by the hierarchical path structure and the existence of role-based 
 * documents, ensuring that security checks are atomic and do not require expensive document lookups 
 * for standard user operations.
 * 
 * DATA STRUCTURE:
 * - /userProfiles/{userId}: Root documents for user information, keyed by the Firebase Auth UID.
 * - /userProfiles/{userId}/libraryVisits/{visitId}: Sub-collection for tracking individual library visits.
 * - /roles_admin/{userId}: A restricted collection used to identify administrative accounts.
 * 
 * KEY SECURITY DECISIONS:
 * 1. Authorization Independence: Ownership is verified by comparing 'request.auth.uid' against 
 *    the '{userId}' segment in the document path.
 * 2. DBAC (Admin Roles): Admin privileges are granted if a document exists at '/roles_admin/$(uid)'. 
 *    This uses "existence over content" for high-performance role checks.
 * 3. Denormalization for Authorization: The 'userId' is stored inside 'LibraryVisit' documents 
 *    to ensure relational integrity, even though the path is the primary source of truth for rules.
 * 4. Structural Segregation: User data is kept in private sub-collections to ensure that 
 *    'list' operations are naturally restricted to the owner's data.
 * 
 * PROTOTYPING MODE:
 * These rules strictly enforce "Who" can access data (Authorization) but are flexible regarding 
 * the specific schema of the data fields (Validation) to allow for rapid development iteration.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    /** @description Checks if the user is authenticated with Firebase Auth. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the authenticated user has an Admin record. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Combines ownership check with existence check for updates/deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the Admin role registry. Only admins can view the registry.
     * @path /roles_admin/{userId}
     * @allow (get) If the user is an Admin.
     * @deny (create) All users; admin roles must be managed via backend/console.
     * @principle DBAC - Existence over content for role-based access.
     */
    match /roles_admin/{userId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if false; // Admin roles managed by privileged system only.
    }

    /**
     * @description Rules for User Profiles. Owners can manage their data; Admins can view/update all.
     * @path /userProfiles/{userId}
     * @allow (create) If the authenticated user is the owner and provides their own UID.
     * @deny (delete) Standard users; profiles should be archived rather than deleted.
     * @principle Relational integrity between Auth UID and Document ID.
     */
    match /userProfiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      // On Create: Ensure the user is creating their own profile and the ID field matches.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      
      // On Update: Ensure the internal ID field remains immutable.
      allow update: if (isExistingOwner(userId) || isAdmin()) 
                    && request.resource.data.id == resource.data.id;
      
      allow delete: if isAdmin();
    }

    /**
     * @description Rules for Library Visit records. Nested under users for automatic scoping.
     * @path /userProfiles/{userId}/libraryVisits/{visitId}
     * @allow (list) If the authenticated user is the owner of the parent profile.
     * @deny (update) If the user attempts to change the 'userId' field (relational link).
     * @principle Path-based authorization for nested resources.
     */
    match /userProfiles/{userId}/libraryVisits/{visitId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isOwner(userId) || isAdmin();

      // On Create: Validate consistency between the path UID and the document's userId field.
      allow create: if isOwner(userId) && request.resource.data.userId == userId;

      // On Update: Ensure the visit cannot be reassigned to another user.
      allow update: if isExistingOwner(userId) 
                    && request.resource.data.userId == resource.data.userId;

      allow delete: if isExistingOwner(userId) || isAdmin();
    }
  }
}