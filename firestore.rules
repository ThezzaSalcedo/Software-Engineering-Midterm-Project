
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * isAdmin: Determines if the current user has administrative privileges.
     * Uses a multi-layered check to handle race conditions during account setup:
     * 1. Direct email check (Best for bootstrap/SSO).
     * 2. Dedicated roles_admin collection check.
     * 3. Role field check in userProfiles.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '') == "admin1@neu.edu.ph" ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.get('role', 'User') == 'Admin'
      );
    }

    function isNotBlocked(userId) {
      // Safely check blocking status with a default fallback to false (not blocked).
      return get(/databases/$(database)/documents/userProfiles/$(userId)).data.get('isBlocked', false) == false;
    }

    // --- COLLECTION RULES ---

    // Administrative roles registration
    match /roles_admin/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      // Allow the specific admin email to bootstrap their own administrative record.
      allow create, update: if isSignedIn() 
                             && request.auth.uid == userId 
                             && request.auth.token.get('email', '') == "admin1@neu.edu.ph";
      allow delete: if false;
    }

    // User profiles and their sub-collections
    match /userProfiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) 
                    && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();

      match /libraryVisits/{visitId} {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) 
                      && request.resource.data.userId == userId
                      && isNotBlocked(userId);
        allow update: if isOwner(userId) 
                      && request.resource.data.userId == resource.data.userId
                      && isNotBlocked(userId);
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // Collection Group rule for 'libraryVisits' across all user profiles.
    // This is used by the Admin Dashboard to show all entries.
    match /{path=**}/libraryVisits/{visitId} {
      allow read: if isAdmin();
    }
  }
}
