
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isNEUEmail() {
      return isSignedIn() && request.auth.token.email.lower().endsWith('@neu.edu.ph');
    }

    /**
     * isAdmin: Comprehensive check for administrative rights.
     * We allow access if:
     * 1. The email is exactly the super admin email.
     * 2. The user has a record in the roles_admin lookup collection.
     * 3. The user profile in /users has the role field set to 'Admin'.
     */
    function isAdmin() {
      return isNEUEmail() && (
        request.auth.token.email == "admin1@neu.edu.ph" ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'User') == 'Admin')
      );
    }

    function isNotBlocked(userId) {
      return !exists(/databases/$(database)/documents/users/$(userId)) || 
             get(/databases/$(database)/documents/users/$(userId)).data.get('isBlocked', false) == false;
    }

    // --- COLLECTION RULES ---

    match /roles_admin/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update: if isSignedIn() && request.auth.token.email == "admin1@neu.edu.ph";
      allow delete: if false;
    }

    // New targeted paths: /users and /visit_logs
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    match /visit_logs/{visitId} {
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() 
                    && request.resource.data.userId == request.auth.uid
                    && isNotBlocked(request.auth.uid);
      allow delete: if isAdmin();
    }
  }
}
