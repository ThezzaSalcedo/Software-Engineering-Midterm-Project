
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isNEUEmail() {
      return isSignedIn() && 
             request.auth.token.email != null && 
             request.auth.token.email.lower().endsWith('@neu.edu.ph');
    }

    /**
     * isAdmin: Direct and efficient check for administrative rights.
     * We prioritize the hardcoded super admin email for immediate access.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "admin1@neu.edu.ph" ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isNotBlocked(userId) {
      // Safe check for blocked status, defaulting to allowed if profile doesn't exist yet
      return !exists(/databases/$(database)/documents/users/$(userId)) || 
             get(/databases/$(database)/documents/users/$(userId)).data.get('isBlocked', false) == false;
    }

    // --- COLLECTION RULES ---

    match /roles_admin/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update: if isSignedIn() && request.auth.token.email == "admin1@neu.edu.ph";
      allow delete: if false;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    match /visit_logs/{visitId} {
      // Allow admins to see all logs, and users to see their own
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() 
                    && request.resource.data.userId == request.auth.uid
                    && isNotBlocked(request.auth.uid);
      allow delete: if isAdmin();
    }
  }
}
